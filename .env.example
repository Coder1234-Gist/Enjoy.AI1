# Copy this file to .env and fill in your values.

# Required — get this from @BotFather on Telegram
BOT_TOKEN=

# Required for Movies & Web Series — free key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional — raises your Google Books rate limit, not required for basic use
GOOGLE_BOOKS_API_KEY=

# Optional — powers the "Industry News" section of the daily digest
# Free tier key from https://newsapi.org/
NEWSAPI_KEY=

# 24h HH:MM, server-local time, for the daily digest
DAILY_NOTIFICATION_TIME=09:00

# SQLite file path
DB_PATH=bot_data.db
